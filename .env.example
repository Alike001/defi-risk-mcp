# Required for `simulate_tx_risk`
TENDERLY_USER=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=

# Required for ABI auto-fetch + on-chain reads
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=

# Optional — Index Network bearer token used by `discover_yields_by_intent`.
#
# When set, the tool shells out to `@indexnetwork/cli`
# (`index opportunity discover "<intent>" --json --token $INDEX_NETWORK_KEY`)
# and lets Claude Desktop participate as an agent in the Index Network
# intent-matching mesh (judge-alignment story — Index Network is on the panel).
#
# When UNSET, the tool falls back to a direct DefiLlama Yields API path
# (`https://yields.llama.fi/pools`) and reports `discovery_source: "fallback"`
# so the MCP client can render an honest "Index unavailable" diagnostic.
#
# To obtain a token: `npm install -g @indexnetwork/cli` → `index login`
# then copy the bearer from `~/.index/credentials.json`.
INDEX_NETWORK_KEY=

# Optional fallback for discovery if Index unavailable
BRAVE_SEARCH_API_KEY=
