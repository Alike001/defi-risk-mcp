# Required for `simulate_tx_risk`
TENDERLY_USER=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=

# Required for ABI auto-fetch + on-chain reads
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=

# Optional — `discover_yields_by_intent` falls back to Brave/DefiLlama if unset
INDEX_NETWORK_KEY=

# Optional fallback for discovery if Index unavailable
BRAVE_SEARCH_API_KEY=
